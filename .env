NODE_ENV=development
PORT=5000

# ── Database ─────────────────────────────────────────────────
# Paste your PostgreSQL connection string here to enable persistent storage.
# Get a free DB at: https://neon.tech  (no credit card required)
# Example: DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
# Leave this commented out to run in memory-only mode (data resets on restart).
 DATABASE_URL=""


# ── Session ─────────────────────────────────────────────────
SESSION_SECRET=""

# ── App URL (used in password-reset links) ────────────────────
# Set this to your production domain in production.
# Example: https://qrmanager.vercel.app
APP_URL=""

# ── Email / SMTP ─────────────────────────────────────────────
# Required for production password-reset emails.
# Leave blank in development — the reset link is shown on the page instead.
#
# Popular provider examples:
#   SendGrid:  SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey         SMTP_PASS=<your_api_key>
#   Gmail:     SMTP_HOST=smtp.gmail.com     SMTP_PORT=587  SMTP_USER=you@gmail.com  SMTP_PASS=<app-password>
#   Resend:    SMTP_HOST=smtp.resend.com    SMTP_PORT=465  SMTP_SECURE=true  SMTP_USER=resend  SMTP_PASS=<api_key>
#   Brevo:     SMTP_HOST=smtp-relay.brevo.com SMTP_PORT=587 SMTP_USER=<your_login>  SMTP_PASS=<smtp_key>
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="adarsh09naik@gmail.com"
SMTP_PASS="fojj pzsw heqt sfff"
EMAIL_FROM="QR-Generator-pro<adarsh09naik@gmail.com>"

# ── Google OAuth ─────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI: http://localhost:5000/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── GitHub OAuth ─────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps
# Callback URL: http://localhost:5000/auth/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
