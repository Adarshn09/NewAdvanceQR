NODE_ENV=development
PORT=5000

# ── Database ─────────────────────────────────────────────────
# Paste your PostgreSQL connection string here to enable persistent storage.
# Get a free DB at: https://neon.tech  (no credit card required)
# Example: DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
# Leave this commented out to run in memory-only mode (data resets on restart).
 DATABASE_URL=""


# ── Session ─────────────────────────────────────────────────
SESSION_SECRET=""

# ── Google OAuth ─────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI: http://localhost:5000/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── GitHub OAuth ─────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps
# Callback URL: http://localhost:5000/auth/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""


